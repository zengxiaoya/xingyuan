{
  "name": "xingyuan",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter xingyuan-server dev\" \"pnpm --filter xingyuan-client dev\"",
    "dev:server": "pnpm --filter xingyuan-server dev",
    "dev:client": "pnpm --filter xingyuan-client dev",
    "install:all": "pnpm install && pnpm --filter server install && pnpm --filter client install",
    "build": "pnpm --filter client build"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "workspaces": [
    "client",
    "server"
  ]
}
